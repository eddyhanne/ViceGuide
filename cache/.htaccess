# Der Full-Page-Cache wird ausschliesslich serverintern per readfile()
# ausgeliefert (siehe cache.php), niemals direkt ueber eine URL. Direktzugriff
# auf die Cache-Dateien daher komplett sperren.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order allow,deny
  Deny from all
</IfModule>
